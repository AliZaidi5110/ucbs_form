# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-secret"

# Field encryption (32-byte hex key for AES-256)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Onboarding token expiry in days
TOKEN_EXPIRY_DAYS="30"

# Email (Resend) — optional for local dev (emails logged to console)
RESEND_API_KEY=""
EMAIL_FROM="onboarding@ucbs.com"

# App URL for links in emails
APP_URL="http://localhost:3000"

# AWS S3 (required for document & photo uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="your-ucbs-onboarding-bucket"

# Legacy upload signing (optional fallback)
UPLOAD_SECRET="change-me-upload-secret-key"

# Demo onboarding in production
ALLOW_DEMO_ONBOARDING="false"
