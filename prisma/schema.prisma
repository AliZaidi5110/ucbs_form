// Prisma schema for UCBS Employee Onboarding Portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  INVITED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
  SELF_DESCRIBE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

model HRUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("HR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id               String         @id @default(cuid())
  employeeId       String         @unique
  fullName         String
  department       String
  designation      String
  reportingManager String?
  dateOfJoining    DateTime
  workLocation     String
  officialEmail    String?
  personalEmail    String?
  mobileNumber     String?
  alternateMobile  String?
  photographUrl    String?
  status           EmployeeStatus @default(INVITED)
  draftData        Json?
  hrRemarks        String?
  submittedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tokens              OnboardingToken[]
  personalDetails     PersonalDetails?
  identificationDetails IdentificationDetails?
  bankDetails         BankDetails?
  education           Education[]
  employmentHistory   EmploymentHistory[]
  professionalSummary ProfessionalSummary?
  itRequest           ITRequest?
  documentUploads     DocumentUpload[]
  acknowledgement     Acknowledgement?
  inductionChecklist  InductionChecklist?
  itAssetAllocations  ITAssetAllocation[]
}

model OnboardingToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([token])
}

model PersonalDetails {
  id                    String        @id @default(cuid())
  employeeId            String        @unique
  employee              Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dateOfBirth           DateTime?
  gender                Gender?
  genderSelfDescribe    String?
  maritalStatus         MaritalStatus?
  bloodGroup            String?
  nationality           String?
  currentAddress        String?
  permanentAddress      String?
  sameAsCurrent         Boolean       @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyRelationship String?
}

model IdentificationDetails {
  id            String  @id @default(cuid())
  employeeId    String  @unique
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  aadhaarNumber String?
  panNumber     String?
  uan           String?
  esic          String?
}

model BankDetails {
  id                String  @id @default(cuid())
  employeeId        String  @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankName          String?
  accountHolderName String?
  accountNumber     String?
  ifscCode          String?
  branch            String?
}

model Education {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  qualification String
  institution  String
  year         String
  percentage   String
  sortOrder    Int      @default(0)
}

model EmploymentHistory {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company         String
  designation     String
  fromDate        String
  toDate          String
  lastDrawnCtc    String?
  reasonForLeaving String?
  sortOrder       Int      @default(0)
}

model ProfessionalSummary {
  id                       String  @id @default(cuid())
  employeeId               String  @unique
  employee                 Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  keySkills                Json
  totalYearsExperience     String?
  relevantIndustryExperience String?
  majorAchievements        String?
}

model ITRequest {
  id                 String   @id @default(cuid())
  employeeId         String   @unique
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  laptopRequired     Boolean  @default(false)
  officialEmailNeeded Boolean @default(false)
  simCardRequired    Boolean  @default(false)
  accessRequired     Json
  accessOther        String?
}

model DocumentUpload {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType String
  fileName     String
  fileUrl      String
  fileKey      String
  mimeType     String?
  uploadedAt   DateTime @default(now())
}

model Acknowledgement {
  id                          String   @id @default(cuid())
  employeeId                  String   @unique
  employee                    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  understoodPolicies          Boolean  @default(false)
  maintainConfidentiality     Boolean  @default(false)
  agreeCompanyRules           Boolean  @default(false)
  understandAttendancePolicy  Boolean  @default(false)
  receivedSafetyInfo          Boolean  @default(false)
  agreeCodeOfConduct          Boolean  @default(false)
  acknowledgeNda              Boolean  @default(false)
  agreeAssetHandling          Boolean  @default(false)
  declarationSignature        String?
  declarationDate             DateTime?
  ndaSignature                String?
  ndaDate                     DateTime?
  codeOfConductSignature      String?
  codeOfConductDate           DateTime?
}

model InductionChecklist {
  id                    String  @id @default(cuid())
  employeeId            String  @unique
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hrOrientation         Boolean @default(false)
  hrOrientationRemarks  String?
  itSetup               Boolean @default(false)
  itSetupRemarks        String?
  emailCreated          Boolean @default(false)
  emailCreatedRemarks   String?
  idCardIssued          Boolean @default(false)
  idCardIssuedRemarks   String?
  payroll               Boolean @default(false)
  payrollRemarks        String?
  attendance            Boolean @default(false)
  attendanceRemarks     String?
  departmentInduction   Boolean @default(false)
  departmentInductionRemarks String?
  safetyBriefing        Boolean @default(false)
  safetyBriefingRemarks String?
}

model ITAssetAllocation {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  asset           String
  assetId         String
  condition       String?
  employeeAck     Boolean  @default(false)
  sortOrder       Int      @default(0)
}
